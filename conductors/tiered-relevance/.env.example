# Copy to .env.local (git-ignored) and fill in. Never commit real keys — this repo is public.
# Summary/task-summary provider preference order: Ollama (default) → Gemini (if key) → Anthropic → deterministic.
# Embeddings default to Ollama `embeddinggemma`; set ACCORDION_EMBED_BACKEND=transformers
# only if you want to use @huggingface/transformers instead.

# Google Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY=
# GEMINI_SUMMARY_MODEL=gemini-2.0-flash

# Anthropic (fallback)
# ANTHROPIC_API_KEY=
# ANTHROPIC_SUMMARY_MODEL=claude-haiku-4-5

# Ollama (default; used first when a local server is up)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_SUMMARY_MODEL=llama3.2:3b
